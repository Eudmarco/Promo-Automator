# Chave da API do Google Gemini (obrigatória)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui

# Modelo Gemini (opcional, padrão: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Origens permitidas para CORS (opcional)
# Separe múltiplas origens por vírgula. Se não definido, o comportamento padrão é same-origin.
# ALLOWED_ORIGINS=https://meuapp.com,https://www.meuapp.com

# URL do app — injetada automaticamente pelo AI Studio em produção
# APP_URL=https://meuapp.run.app
